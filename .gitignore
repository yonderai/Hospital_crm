# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/backend/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# logs and temp files
*.log
*.txt
*.json
*.pdf
!package.json
!tsconfig.json
!package-lock.json
!backend/package.json
!backend/package-lock.json
!eslint.config.mjs
!postcss.config.mjs
!next.config.ts
check_*.js
seed_*.js
!seed_fix.js
!src/scripts/
debug_*.js
debug_*.ts
*_out.txt
*_errors.txt
build_*.txt
diag.txt

# Uploads directory (exclude uploaded files but keep directory structure)
/public/uploads/*
!/public/uploads/.gitkeep

# Python
venv/
env/
__pycache__/
*.pyc

